<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="你想要什么">
<link rel="apple-touch-icon" href="https://i.postimg.cc/RhzSF9PV/IMG-3285.jpg">
<link rel="manifest" href="manifest.json">
<title>你想要什么？</title>
<meta charset="UTF-8">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body {
    width: 100%;
    height: 100%;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    overflow: hidden;
    background-color: #000;
}
#bg-layer {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-size: cover;
    background-position: center;
    z-index: -1;
}
#content-layer {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: white;
    font-family: 'user-font', 'KaiTi', 'STKaiti', serif;
}
#custom-text { font-size: 1.2em; margin-bottom: 15px; opacity: 0.9; outline: none; border-bottom: 1px dashed rgba(255,255,255,0.5); padding-bottom: 5px; min-width: 200px; text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.8); }
h1 { font-size: 2.5em; margin-bottom: 40px; text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.8); margin-top: 0; }
#options-container { display: flex; flex-direction: column; gap: 20px; }
.option { padding: 12px 25px; border: 1px solid white; border-radius: 10px; cursor: pointer; transition: opacity 0.2s ease-out; background-color: rgba(0, 0, 0, 0.3); text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.7); }
#settings-container { position: absolute; left: 20px; bottom: calc(20px + env(safe-area-inset-bottom)); z-index: 100; }
.main-btn, .sub-btn { padding: 10px 15px; background: rgba(0, 0, 0, 0.6); color: white; border-radius: 8px; cursor: pointer; font-size: 14px; border: none; display: flex; align-items: center; justify-content: center; margin-bottom: 5px; }
#sub-buttons { display: none; flex-direction: column; gap: 10px; margin-bottom: 10px; }
input[type="file"] { display: none; }
#color-palette { display: none; flex-wrap: wrap; gap: 8px; background: rgba(0, 0, 0, 0.6); padding: 10px; border-radius: 8px; width: 140px; justify-content: center; }
.color-swatch { width: 25px; height: 25px; border-radius: 50%; cursor: pointer; border: 1px solid rgba(255,255,255,0.5); }
#timeline-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 1000; flex-direction: column; align-items: center; justify-content: center; color: white; }
#timeline-container { width: 90%; height: 70%; overflow-x: auto; overflow-y: hidden; display: flex; gap: 10px; padding: 20px; border: 1px solid rgba(255,255,255,0.2); border-radius: 10px; background: rgba(0,0,0,0.5); position: relative; }
.day-column { display: flex; flex-direction: column; width: 30px; flex-shrink: 0; }
.day-header { font-size: 10px; text-align: center; margin-bottom: 5px; opacity: 0.8; cursor: pointer; color: #ff99cc; text-decoration: underline; }
.hour-cell { flex: 1; margin-bottom: 2px; background: rgba(255,255,255,0.1); border-radius: 2px; }
.hour-cell.active { background: #ff99cc; box-shadow: 0 0 5px #ff99cc; }
#close-timeline { margin-top: 20px; padding: 10px 20px; background: rgba(255,255,255,0.2); border-radius: 8px; cursor: pointer; border: none; color: white; }
.timer-status { font-size: 12px; color: #ff99cc; margin-top: 5px; display: none; text-shadow: 1px 1px 2px black; }
#detail-modal { display: none; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(0,0,0,0.95); padding: 20px; border-radius: 10px; border: 1px solid #ff99cc; color: white; z-index: 1001; min-width: 200px; max-height: 80%; overflow-y: auto; box-shadow: 0 0 15px rgba(255,153,204,0.5); }
#detail-list { list-style: none; padding: 0; margin: 0 0 15px 0; font-size: 14px; line-height: 2; }
</style>
</head>
<body>
<div id="bg-layer"></div>
<div id="content-layer">
<div id="custom-text" contenteditable="true" spellcheck="false">点击这里输入自定义句子</div>
<h1>现在是什么想要？</h1>
<div id="options-container">
<div class="option" onclick="handleClick(this)">想要控制</div>
<div class="option" onclick="handleClick(this)">想要认同</div>
<div class="option" onclick="handleClick(this)">想要安全</div>
</div>
<div id="settings-container">
<div id="sub-buttons">
<div id="fullscreen-btn" class="sub-btn">进入全屏</div>
<label for="wallpaper-upload" class="sub-btn">更换壁纸</label>
<label for="font-upload" class="sub-btn">更换字体</label>
<div id="color-btn" class="sub-btn">更换颜色</div>
<div id="color-palette">
<div class="color-swatch" style="background:#ffffff;" onclick="changeColor('#ffffff')"></div>
<div class="color-swatch" style="background:#ff9999;" onclick="changeColor('#ff9999')"></div>
<div class="color-swatch" style="background:#99ccff;" onclick="changeColor('#99ccff')"></div>
<div class="color-swatch" style="background:#99ff99;" onclick="changeColor('#99ff99')"></div>
<div class="color-swatch" style="background:#ffff99;" onclick="changeColor('#ffff99')"></div>
<div class="color-swatch" style="background:#cc99ff;" onclick="changeColor('#cc99ff')"></div>
<div class="color-swatch" style="background:#ffcc99;" onclick="changeColor('#ffcc99')"></div>
<div class="color-swatch" style="background:#000000;" onclick="changeColor('#000000')"></div>
</div>
<div id="start-timer-btn" class="sub-btn">开始计时</div>
<div id="stop-timer-btn" class="sub-btn" style="display:none; background:rgba(255,100,100,0.6);">结束计时</div>
<div id="view-timeline-btn" class="sub-btn">查看时间轴</div>
</div>
<button id="main-settings-btn" class="main-btn">设置</button>
<div id="timer-display" class="timer-status">计时中...</div>
</div>
</div>
<input type="file" id="wallpaper-upload" accept="image/*">
<input type="file" id="font-upload" accept=".ttf,.otf,.woff,.woff2">
<div id="timeline-modal">
<h3>时间轴记录</h3>
<div id="timeline-container"></div>
<button id="close-timeline">关闭</button>
<div id="detail-modal">
<h4 id="detail-title" style="margin-top:0; color:#ff99cc;">详细记录</h4>
<ul id="detail-list"></ul>
<button onclick="document.getElementById('detail-modal').style.display='none'" style="padding:5px 15px; background:#ff99cc; color:black; border:none; border-radius:5px; cursor:pointer; width:100%;">关闭</button>
</div>
</div>
<script>
const bgLayer = document.getElementById('bg-layer'); const customText = document.getElementById('custom-text'); const colorPalette = document.getElementById('color-palette'); let records = JSON.parse(localStorage.getItem('myTimeRecords') || '[]'); let currentTimer = localStorage.getItem('myCurrentTimer'); const startBtn = document.getElementById('start-timer-btn'); const stopBtn = document.getElementById('stop-timer-btn'); const timerDisplay = document.getElementById('timer-display');
document.addEventListener('DOMContentLoaded', () => { const savedText = localStorage.getItem('myCustomText'); if (savedText) customText.innerText = savedText; const savedColor = localStorage.getItem('myCustomColor'); if (savedColor) customText.style.color = savedColor; const savedWallpaper = localStorage.getItem('myWallpaper'); if (savedWallpaper) bgLayer.style.backgroundImage = `url(${savedWallpaper})`; const savedFont = localStorage.getItem('myCustomFont'); if (savedFont) { const style = document.createElement('style'); style.id = 'custom-font-style'; style.textContent = `@font-face { font-family: 'user-font'; src: url(${savedFont}); }`; document.head.appendChild(style); } if (currentTimer) { startBtn.style.display = 'none'; stopBtn.style.display = 'flex'; timerDisplay.style.display = 'block'; } });
customText.addEventListener('input', () => { localStorage.setItem('myCustomText', customText.innerText); });
document.getElementById('color-btn').addEventListener('click', (e) => { e.stopPropagation(); colorPalette.style.display = colorPalette.style.display === 'flex' ? 'none' : 'flex'; });
function changeColor(color) { customText.style.color = color; localStorage.setItem('myCustomColor', color); colorPalette.style.display = 'none'; }
function handleClick(element) { element.style.opacity = '0'; setTimeout(() => { element.style.opacity = '1'; }, 200); }
const mainBtn = document.getElementById('main-settings-btn'); const subBtns = document.getElementById('sub-buttons'); mainBtn.addEventListener('click', (e) => { e.stopPropagation(); subBtns.style.display = subBtns.style.display === 'flex' ? 'none' : 'flex'; });
document.addEventListener('click', (e) => { if (!mainBtn.contains(e.target) && !document.getElementById('color-btn').contains(e.target) && !colorPalette.contains(e.target)) { subBtns.style.display = 'none'; colorPalette.style.display = 'none'; } });
document.getElementById('wallpaper-upload').addEventListener('change', function(event) { const file = event.target.files[0]; if (file) { const reader = new FileReader(); reader.onload = function(e) { const imageUrl = e.target.result; bgLayer.style.backgroundImage = `url(${imageUrl})`; try { localStorage.setItem('myWallpaper', imageUrl); } catch (error) { alert('图片太大无法保存。'); } }; reader.readAsDataURL(file); } });
document.getElementById('font-upload').addEventListener('change', function(event) { const file = event.target.files[0]; if (file) { const reader = new FileReader(); reader.onload = function(e) { const fontUrl = e.target.result; const oldStyle = document.getElementById('custom-font-style'); if(oldStyle) oldStyle.remove(); const style = document.createElement('style'); style.id = 'custom-font-style'; style.textContent = `@font-face { font-family: 'user-font'; src: url(${fontUrl}); }`; document.head.appendChild(style); try { localStorage.setItem('myCustomFont', fontUrl); } catch (error) { alert('字体文件太大无法保存。'); } }; reader.readAsDataURL(file); } });
startBtn.addEventListener('click', (e) => { e.stopPropagation(); currentTimer = Date.now().toString(); localStorage.setItem('myCurrentTimer', currentTimer); startBtn.style.display = 'none'; stopBtn.style.display = 'flex'; timerDisplay.style.display = 'block'; });
stopBtn.addEventListener('click', (e) => { e.stopPropagation(); if (currentTimer) { records.push({ start: parseInt(currentTimer), end: Date.now() }); localStorage.setItem('myTimeRecords', JSON.stringify(records)); localStorage.removeItem('myCurrentTimer'); currentTimer = null; } startBtn.style.display = 'flex'; stopBtn.style.display = 'none'; timerDisplay.style.display = 'none'; renderTimeline(); });
document.getElementById('view-timeline-btn').addEventListener('click', (e) => { e.stopPropagation(); renderTimeline(); document.getElementById('timeline-modal').style.display = 'flex'; subBtns.style.display = 'none'; });
document.getElementById('close-timeline').addEventListener('click', () => { document.getElementById('timeline-modal').style.display = 'none'; document.getElementById('detail-modal').style.display = 'none'; });
function formatTime(ts) { const d = new Date(ts); return d.getHours().toString().padStart(2, '0') + ':' + d.getMinutes().toString().padStart(2, '0'); }
function showDayDetail(dayStart) { const dayEnd = dayStart + 86400000; let allRecords = [...records]; if (currentTimer) { allRecords.push({ start: parseInt(currentTimer), end: Date.now() }); } const dayRecords = allRecords.filter(r => r.start < dayEnd && r.end > dayStart); const list = document.getElementById('detail-list'); list.innerHTML = ''; if(dayRecords.length === 0) { list.innerHTML = '<li>无记录</li>'; } else { dayRecords.forEach(r => { const s = Math.max(r.start, dayStart); const e = Math.min(r.end, dayEnd); list.innerHTML += `<li>${formatTime(s)} - ${formatTime(e)}</li>`; }); } const d = new Date(dayStart); document.getElementById('detail-title').innerText = `${d.getMonth()+1}月${d.getDate()}日 详情`; document.getElementById('detail-modal').style.display = 'block'; }
function renderTimeline() { const container = document.getElementById('timeline-container'); container.innerHTML = ''; let allRecords = [...records]; if (currentTimer) { allRecords.push({ start: parseInt(currentTimer), end: Date.now() }); } if (allRecords.length === 0) { container.innerHTML = '<div style="margin:auto;">还没有计时记录哦</div>'; return; } const firstTime = Math.min(...allRecords.map(r => r.start)); const lastTime = Math.max(...allRecords.map(r => r.end)); let currentDay = new Date(firstTime); currentDay.setHours(0,0,0,0); const endDay = new Date(lastTime); endDay.setHours(23,59,59,999); while (currentDay <= endDay) { const col = document.createElement('div'); col.className = 'day-column'; const header = document.createElement('div'); header.className = 'day-header'; header.innerText = `${currentDay.getMonth()+1}/${currentDay.getDate()}`; const dayStart = currentDay.getTime(); header.onclick = () => showDayDetail(dayStart); col.appendChild(header); for (let h = 0; h < 24; h++) { const cell = document.createElement('div'); cell.className = 'hour-cell'; const hourStart = dayStart + h * 3600000; const hourEnd = hourStart + 3600000; const isActive = allRecords.some(r => r.start < hourEnd && r.end > hourStart); if (isActive) cell.classList.add('active'); col.appendChild(cell); } container.appendChild(col); currentDay.setDate(currentDay.getDate() + 1); } setTimeout(() => container.scrollLeft = container.scrollWidth, 50); }

const fullscreenBtn = document.getElementById('fullscreen-btn');
fullscreenBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const elem = document.documentElement;
    if (elem.requestFullscreen) {
        elem.requestFullscreen();
    } else if (elem.webkitRequestFullscreen) { 
        elem.webkitRequestFullscreen();
    } else if (elem.msRequestFullscreen) { 
        elem.msRequestFullscreen();
    }
    subBtns.style.display = 'none'; 
});
</script>
</body>
</html>
